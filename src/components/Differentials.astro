---
import { Icon } from 'astro-icon/components';

const items = [
  {
    icon: "heroicons:cpu-chip",
    title: "Tecnología Avanzada",
    description: "Equipos de última generación para diagnósticos precisos y tratamientos más cómodos.",
  },
  {
    icon: "heroicons:user-circle",
    title: "Atención Personalizada",
    description: "Cada paciente es único. Te escuchamos y diseñamos el plan ideal para tu sonrisa.",
  },
  {
    icon: "heroicons:heart",
    title: "Trabajamos con Amor",
    description: "La Dra. Francela Monge y su equipo te cuidan con dedicación y calidez en cada visita.",
  },
];
---

<section id="nosotros" class="py-20 bg-base-200">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-base-content mb-4">¿Por qué elegirnos?</h2>
      <p class="text-secondary text-lg max-w-xl mx-auto">Nuestro compromiso va más allá de la atención dental.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {items.map((item) => (
        <div class="card bg-base-100 shadow-md hover:shadow-lg transition-shadow">
          <div class="card-body items-center text-center">
            <Icon name={item.icon} class="w-14 h-14 text-primary mb-2" />
            <h3 class="card-title text-xl">{item.title}</h3>
            <p class="text-secondary">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
