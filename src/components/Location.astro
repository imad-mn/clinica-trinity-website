---
import { Icon } from 'astro-icon/components';
---

<section id="ubicacion" class="py-20 bg-base-200">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-base-content mb-3">
        ¿Dónde estamos?
      </h2>
      <p class="text-base-content/60 text-lg">
        Fácil acceso en Tres Ríos, Costa Rica
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">

      <!-- Info de ubicación -->
      <div class="flex flex-col gap-6">

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
            <Icon name="heroicons:map-pin-solid" class="w-5 h-5 text-primary" />
          </div>
          <div>
            <p class="font-semibold text-base-content text-sm mb-1">Dirección</p>
            <p class="text-base-content/70 text-sm leading-relaxed">
              800 metros este de la iglesia católica,<br />
              Tres Ríos, Cartago, Costa Rica
            </p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
            <Icon name="heroicons:clock-solid" class="w-5 h-5 text-primary" />
          </div>
          <div>
            <p class="font-semibold text-base-content text-sm mb-1">Horario</p>
            <p class="text-base-content/70 text-sm leading-relaxed">
              Lunes – Viernes: 8:00 am – 6:00 pm<br />
              Sábados: con cita previa
            </p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
            <Icon name="heroicons:phone-solid" class="w-5 h-5 text-primary" />
          </div>
          <div>
            <p class="font-semibold text-base-content text-sm mb-1">Teléfono</p>
            <a
              href="tel:+50683561395"
              class="text-base-content/70 text-sm hover:text-primary transition-colors"
            >
              +506 8356-1395
            </a>
          </div>
        </div>

        <a
          href="https://maps.app.goo.gl/D73QTG3dsdNPcgNx5"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-sm gap-2 w-fit mt-2"
        >
          <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4" />
          Abrir en Google Maps
        </a>

      </div>

      <!-- Mapa embed -->
      <div class="lg:col-span-2 rounded-2xl overflow-hidden shadow-lg border border-base-content/10 h-80 lg:h-96">
        <iframe
          src="https://www.google.com/maps?q=Cl%C3%ADnica+Trinity+Tres+R%C3%ADos+Costa+Rica&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación Clínica Trinity en Google Maps"
        ></iframe>
      </div>

    </div>
  </div>
</section>
