---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Clínica Trinity Especialidades Dentales",
  description = "Atención dental especializada con tecnología moderna y calor humano. Ubicados en Tres Ríos, Costa Rica.",
} = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="trinity">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/webp" href="/Clinica_Trinity.webp" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-base-100 text-base-content">
    <slot />
  </body>
</html>
